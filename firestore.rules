rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }
    
    function hasRole(role) {
      let data = getUserData();
      return isSignedIn() && data != null && data.role == role;
    }

    // =============================================
    // USER PROFILES (Students, Recruiters, Admins)
    // =============================================
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == userId || hasRole('admin');
      
      // User's own subcollections: savedResumes, analysisHistory
      match /savedResumes/{resumeId} {
        allow read: if isSignedIn();
        allow write: if request.auth.uid == userId || hasRole('admin');
      }
      
      match /analysisHistory/{historyId} {
        allow read: if isSignedIn();
        allow write: if request.auth.uid == userId || hasRole('admin');
      }
      
      // Application records stored under student profiles
      // Recruiters and Admins need write access to update status
      match /applications/{appId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      // Notifications stored under student profiles
      match /notifications/{notificationId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // =============================================
    // JOBS (On-Campus + Off-Campus)
    // =============================================
    match /jobs/{jobId} {
      allow read: if true;
      allow write: if isSignedIn();
      
      // Applications submitted to this job
      match /applications/{applicantId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // =============================================
    // INTERVIEW EXPERIENCES
    // =============================================
    match /interviewExperiences/{experienceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.userId || hasRole('admin')
      );
    }
  }
}
